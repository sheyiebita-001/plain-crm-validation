# Copy this file to .env.local and fill in real values from phase-1-secrets.txt.
# Never commit .env.local — it is gitignored.

# === Supabase (Phase 1) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# === Smartlead (Phase 1) ===
SMARTLEAD_API_KEY=your_smartlead_api_key
SMARTLEAD_WEBHOOK_SECRET=your_random_64_char_secret

# === Resend (Phase 1.5 — sign up before Batch 5) ===
RESEND_API_KEY=

# === Site config ===
NEXT_PUBLIC_SITE_URL=https://trysignalbench.com
ADMIN_EMAIL=sheyi@trysignalbench.com

# === Unsubscribe HMAC (Batch 7 — generate any 64-char alphanumeric) ===
UNSUBSCRIBE_SIGNING_SECRET=your_random_64_char_secret

# === Calendar (Phase 5 — set before cold sending starts) ===
CALENDAR_URL=

# === Plausible (Batch 4) ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=trysignalbench.com
